{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/sitemap",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    }
  ],
  "routes": [
    { "src": "/sitemap\.xml", "dest": "/api/sitemap" },
    { "src": "/sitemap",      "dest": "/api/sitemap" },
    { "src": "/(.*)",         "dest": "/index.html", "check": true }
  ]
}
