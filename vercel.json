{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/sitemap\\.xml",
      "dest": "/api/sitemap",
      "headers": { "Content-Type": "application/xml; charset=utf-8" }
    },
    {
      "src": "/sitemap",
      "dest": "/api/sitemap",
      "headers": { "Content-Type": "application/xml; charset=utf-8" }
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
